# Slack App credentials
# Found at https://api.slack.com/apps → your app → OAuth & Permissions / Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Optional: enable Socket Mode (requires "Socket Mode" in Slack app settings + App-Level Token)
# If set, the app uses WebSocket instead of HTTP — no public URL needed.
# SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Planka API
PLANKA_BASE_URL=https://your-planka-instance.example.com
PLANKA_EMAIL=your-planka-bot-account@example.com
PLANKA_PASSWORD=your-planka-bot-password

# HTTP port (only used when NOT in socket mode)
PORT=3000
